    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#administra_recurso</IRI>
        <Literal>Conecta el SO con la RAM gestionada, las particiones Swap, o discos físicos</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#es_variante_de</IRI>
        <Literal>Para indicar que Ubuntu es variante de Debian, o Windows 11 de Windows 10.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#esta_formateado_con</IRI>
        <Literal>Para enlazar directamente que una partición física de disco tiene un formato ext4, independientemente del SO.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#se_conecta_a_infraestructura</IRI>
        <Literal>Relación más general para servidores NTP (hora), servidores DNS por defecto, etc.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#se_descarga_desde</IRI>
        <Literal>De dónde saca los paquetes de instalación</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#soporta_lectura_nativa_fs</IRI>
        <Literal>Formatos que puede leer sin instalar nada extra</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#tiene_sistema_archivos_por_defecto</IRI>
        <Literal>El formato que usa al instalarse</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#utiliza_estructura_datos</IRI>
        <Literal>Para indicar qué usa el kernel internamente</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>owl:topObjectProperty</AbbreviatedIRI>
        <Literal>Para conectar el SO con sus demonios (ej. systemd), controladores o librerías gráficas.</Literal>
    </AnnotationAssertion>
